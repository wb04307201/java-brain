{
  "mcpServers": {
    "bing-search": {
      "args": [
        "-y",
        "bing-cn-mcp"
      ],
      "command": "npx.cmd"
    },
    "@tokenizin-agency/mcp-npx-fetch": {
      "command": "npx.cmd",
      "args": [
        "-y",
        "@tokenizin/mcp-npx-fetch"
      ]
    },
    "sequential-thinking": {
      "command": "npx.cmd",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "playwright": {
      "command": "npx.cmd",
      "args": [
        "@playwright/mcp@latest"
      ]
    },
    "chrome-devtools": {
      "args": [
        "chrome-devtools-mcp@latest"
      ],
      "command": "npx.cmd"
    },
    "http-mcp": {
      "args": [
        "io.github.wb04307201:http-mcp:1.0.0"
      ],
      "command": "jbang.cmd"
    },
    "mcp-server-chart": {
      "args": [
        "-y",
        "@antv/mcp-server-chart"
      ],
      "command": "npx.cmd"
    },
    "sql-forge-mcp": {
      "args": [
        "io.github.wb04307201:sql-forge-mcp:1.6.1",
        "--sql.forge.mcp.systems[0].name=order_system",
        "--sql.forge.mcp.systems[0].url=http://localhost:8081",
        "--sql.forge.mcp.systems[0].description=Order Management System",
        "--sql.forge.mcp.systems[0].apiKey=test"
      ],
      "env": {
        "JAVA_TOOL_OPTIONS": "-Dfile.encoding=UTF-8 -Dsun.jnu.encoding=UTF-8"
      },
      "command": "jbang.cmd"
    }
  }
}